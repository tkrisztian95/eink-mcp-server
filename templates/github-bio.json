{
  "name": "github-bio",
  "description": "GitHub user bio card showing profile info (bio, company, location, repo count) and a bar chart of the last 7 active days with commit counts.",
  "tags": ["github", "profile", "bio", "developer", "activity", "commits"],
  "tool": "render_layout",
  "spec": {
    "rotation": 180,
    "sections": [
      {
        "type": "image_block",
        "path": "assets/github-mark.svg",
        "width": 48
      },
      {
        "type": "header",
        "title": "@username",
        "subtitle": "Full Name"
      },
      {
        "type": "divider"
      },
      {
        "type": "stat_block",
        "label": ">> Bio",
        "value": "Bio / role description"
      },
      {
        "type": "stat_block",
        "label": "@ Company",
        "value": "@company"
      },
      {
        "type": "stat_block",
        "label": "~ Location",
        "value": "City, Country"
      },
      {
        "type": "stat_block",
        "label": "# Repos",
        "value": "NNN"
      },
      {
        "type": "divider",
        "margin_before": 8,
        "margin_after": 4
      },
      {
        "type": "text_row",
        "left": "Activity (last 7 active days)",
        "size": "small",
        "bold": true
      },
      {
        "type": "spacer",
        "height": 4
      },
      {
        "type": "bar_chart",
        "title": null,
        "data": [
          { "label": "Day 1", "value": 0 },
          { "label": "Day 2", "value": 0 },
          { "label": "Day 3", "value": 0 },
          { "label": "Day 4", "value": 0 },
          { "label": "Day 5", "value": 0 },
          { "label": "Day 6", "value": 0 },
          { "label": "Day 7", "value": 0 }
        ]
      }
    ]
  }
}
