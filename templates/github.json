{
  "name": "github",
  "description": "GitHub display card with two layout options. Use 'profile' for social stats (followers, stars, top language, weekly commits by weekday). Use 'bio' for profile info (bio text, company, location, repo count, last 7 active days activity chart).",
  "tags": ["github", "profile", "bio", "git", "developer", "code", "commits", "activity", "followers", "stats"],
  "tool": "render_layout",
  "layouts": {
    "profile": {
      "description": "Social stats card: followers/following counts, total stars, top language, and a 7-day commit bar chart by weekday.",
      "spec": {
        "padding": 20,
        "sections": [
          {
            "type": "image_block",
            "path": "assets/github-mark.svg",
            "width": 48
          },
          {
            "type": "header",
            "title": "@username",
            "subtitle": "github.com"
          },
          {
            "type": "divider",
            "bold": true
          },
          {
            "type": "text_row",
            "left": "Full Name",
            "right": "⭐ NNN stars",
            "size": "label",
            "bold": true
          },
          {
            "type": "text_row",
            "left": "Followers: NNN",
            "right": "Following: NNN"
          },
          {
            "type": "text_row",
            "left": "Repos: NNN",
            "right": "Top lang: Language"
          },
          {
            "type": "divider",
            "light": true
          },
          {
            "type": "bar_chart",
            "title": "Commits last 7 days",
            "data": [
              { "label": "Mon", "value": 0 },
              { "label": "Tue", "value": 0 },
              { "label": "Wed", "value": 0 },
              { "label": "Thu", "value": 0 },
              { "label": "Fri", "value": 0 },
              { "label": "Sat", "value": 0 },
              { "label": "Sun", "value": 0 }
            ]
          }
        ]
      }
    },
    "bio": {
      "description": "Profile info card: bio text, company, location, repo count, and a bar chart of the last 7 active days with commit counts. Rendered rotated 180°.",
      "spec": {
        "rotation": 180,
        "sections": [
          {
            "type": "image_block",
            "path": "assets/github-mark.svg",
            "width": 48
          },
          {
            "type": "header",
            "title": "@username",
            "subtitle": "Full Name"
          },
          {
            "type": "divider"
          },
          {
            "type": "stat_block",
            "label": ">> Bio",
            "value": "Bio / role description"
          },
          {
            "type": "stat_block",
            "label": "@ Company",
            "value": "@company"
          },
          {
            "type": "stat_block",
            "label": "~ Location",
            "value": "City, Country"
          },
          {
            "type": "stat_block",
            "label": "# Repos",
            "value": "NNN"
          },
          {
            "type": "divider",
            "margin_before": 8,
            "margin_after": 4
          },
          {
            "type": "text_row",
            "left": "Activity (last 7 active days)",
            "size": "small",
            "bold": true
          },
          {
            "type": "spacer",
            "height": 4
          },
          {
            "type": "bar_chart",
            "title": null,
            "data": [
              { "label": "Day 1", "value": 0 },
              { "label": "Day 2", "value": 0 },
              { "label": "Day 3", "value": 0 },
              { "label": "Day 4", "value": 0 },
              { "label": "Day 5", "value": 0 },
              { "label": "Day 6", "value": 0 },
              { "label": "Day 7", "value": 0 }
            ]
          }
        ]
      }
    }
  }
}
